---
layout: base.njk
pageType: article
---
<article class="blog-post content">
  <div class="container blog-post-container">
    <a href="/blog/" class="blog-back">&larr; Back to the Journal</a>
    <div class="eyebrow">Journal</div>
    <h1 class="blog-post-title">{{ title }}</h1>
    <div class="blog-post-meta">
      <span>{{ date | readableDate }}</span>
      <span class="blog-post-dot">·</span>
      <span>{{ author or site.author }}</span>
    </div>
  </div>

  {% if image %}
  <div class="blog-post-hero">
    <div class="container blog-post-container">
      <img src="{{ image | assetUrl }}" alt="{{ title }}">
    </div>
  </div>
  {% endif %}

  <div class="container blog-post-container">
    <div class="blog-post-body">
      {{ content | safe }}
    </div>

    {% if tags and tags.length %}
    <div class="blog-tags">
      {% for t in tags %}<a class="blog-tag" href="/blog/tag/{{ t | slugify }}/">{{ t }}</a>{% endfor %}
    </div>
    {% endif %}

    <div class="blog-post-foot">
      <a href="/blog/" class="blog-back">&larr; Back to the Journal</a>
    </div>
  </div>
</article>

{% set related = collections.posts | relatedPosts(page.url, tags, 3) %}
{% if related and related.length %}
<section class="section blog-related">
  <div class="container">
    <div class="eyebrow" style="text-align:center;">More from the Journal</div>
    <div class="blog-grid blog-related-grid">
      {% for post in related %}
      <a class="blog-card" href="{{ post.url }}">
        <div class="blog-card-img">
          <img src="{{ (post.data.image | assetUrl) or site.defaultImage }}" alt="{{ post.data.title }}" loading="lazy">
        </div>
        <div class="blog-card-body">
          <div class="blog-card-date">{{ post.date | readableDate }}</div>
          <h3 class="blog-card-title">{{ post.data.title }}</h3>
          <span class="blog-card-more">Read More &rarr;</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Closing CTA -->
<section class="section blog-cta-section">
  <div class="container" style="text-align:center;max-width:720px;">
    <div class="eyebrow">Begin When You&rsquo;re Ready</div>
    <h2>The first step is reaching out</h2>
    <p style="margin-top:1.2rem;">A free 15-minute consultation is offered to determine fit and answer any questions before starting.</p>
    <a href="tel:+19513956089" class="cta">Schedule a Consultation</a>
  </div>
</section>
